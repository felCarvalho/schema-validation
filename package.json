{
    "name": "@felipe-lib/schema-local",
    "version": "1.1.3",
    "description": "Biblioteca de validação simples, leve e agnóstica com NotificationPattern e ResultPattern para respostas padronizadas",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "export": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "validacao",
        "schema",
        "validador",
        "types",
        "notification",
        "result",
        "pattern"
    ],
    "author": "Felca",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/felca/schemaValidation.git"
    },
    "devDependencies": {
        "typescript": "^6.0.3"
    },
    "packageManager": "pnpm@10.20.0"
}
